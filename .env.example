# Supabase (required for app, Value Agent chat, and generate-google-docs)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Or use VITE_SUPABASE_PUBLISHABLE_KEY (same anon key) for backward compatibility

# Google OAuth for report export (Google Slides / Google Docs)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional: Case study slides — GVA Case Study Deck ID. Slides for selected benefits are copied into the deck.
VITE_CASE_STUDY_SOURCE_PRESENTATION_ID=1wlyYro10z9rBKZ62BQCK3XvgWnB_KrNWTl65LGMlzng

# Value Agent: LOVABLE_API_KEY is NOT set here. It must be set in Supabase
# Edge Function secrets (Dashboard → Project Settings → Edge Functions).
# See VALUE_AGENT_SETUP.md for full setup.
